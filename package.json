{
  "name": "setu-client",
  "version": "1.0.0",
  "description": "Production-grade TypeScript SDK for the Setu API Platform (UPI, BBPS, KYC, AA, eSign)",
  "license": "MIT",
  "author": "setu-node contributors",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./payments/upi": {
      "import": "./dist/payments/upi.js",
      "require": "./dist/payments/upi.cjs",
      "types": "./dist/payments/upi.d.ts"
    },
    "./payments/bbps": {
      "import": "./dist/payments/bbps.js",
      "require": "./dist/payments/bbps.cjs",
      "types": "./dist/payments/bbps.d.ts"
    },
    "./data/aa": {
      "import": "./dist/data/aa.js",
      "require": "./dist/data/aa.cjs",
      "types": "./dist/data/aa.d.ts"
    },
    "./data/esign": {
      "import": "./dist/data/esign.js",
      "require": "./dist/data/esign.cjs",
      "types": "./dist/data/esign.d.ts"
    },
    "./data/kyc": {
      "import": "./dist/data/kyc/index.js",
      "require": "./dist/data/kyc/index.cjs",
      "types": "./dist/data/kyc/index.d.ts"
    },
    "./webhook": {
      "import": "./dist/webhook/index.js",
      "require": "./dist/webhook/index.cjs",
      "types": "./dist/webhook/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --ext .ts",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "setu",
    "upi",
    "bbps",
    "kyc",
    "account-aggregator",
    "esign",
    "fintech",
    "india",
    "payments"
  ],
   "repository": {
    "type": "git",
    "url": "git+https://github.com/iamkanishka/setu-client.git"
  },
  "homepage": "https://github.com/iamkanishka/setu-client#readme",
  "bugs": {
    "url": "https://github.com/iamkanishka/setu-client/issues"
  },
  "funding": "https://github.com/sponsors/iamkanishka"
}
